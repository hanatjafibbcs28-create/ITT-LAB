# 1. Get Input from user
raw_input = input("Enter array elements (separated by space): ").split()
nums = []
for x in raw_input:
    nums.append(int(x))

target = int(input("Enter target sum (e.g. 0): "))

# 2. Sort the array (Crucial for handling duplicates and using pointers)
nums.sort()
results = []
n = len(nums)

# 3. Logic: Four-pointer approach (Two loops + Two pointers)
for i in range(n - 3):
    # Skip the same number to avoid duplicate quadruplets
    if i > 0 and nums[i] == nums[i - 1]:
        continue
        
    for j in range(i + 1, n - 2):
        # Skip the same number for the second position
        if j > i + 1 and nums[j] == nums[j - 1]:
            continue
            
        # Two-pointer logic for the remaining two numbers
        left = j + 1
        right = n - 1
        
        while left < right:
            current_sum = nums[i] + nums[j] + nums[left] + nums[right]
            
            if current_sum == target:
                results.append([nums[i], nums[j], nums[left], nums[right]])
                
                # Move pointers and skip duplicates
                while left < right and nums[left] == nums[left + 1]:
                    left += 1
                while left < right and nums[right] == nums[right - 1]:
                    right -= 1
                
                left += 1
                right -= 1
            elif current_sum < target:
                left += 1
            else:
                right -= 1

# 4. Display the results
print("\nUnique Quadruplets:")
if len(results) == 0:
    print("None found.")
else:
    for quad in results:
        print(quad)
