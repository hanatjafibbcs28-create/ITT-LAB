import operator

def person_lister(f):
    def inner(people):
       # Sort the nested list based on the age field (index 2).
        # We wrap int() around itemgetter(2) using a lambda to ensure numerical sorting.
        # Python's sorted() is stable, preserving input order for identical ages.
        sorted_people = sorted(people, key=lambda x: int(operator.itemgetter(2)(x)))
        
        # Apply the name_format function 'f' to each sorted person list
        return [f(person) for person in sorted_people]
    return inner

@person_lister
def name_format(person):
    return ("Mr. " if person[3] == "M" else "Ms. ") + person[0] + " " + person[1]

if __name__ == '__main__':
    people = [input().split() for i in range(int(input()))]
    print(*name_format(people), sep='\n')
