#include <stdio.h>
#include <stdlib.h>

/*
 * This stores the total number of books in each shelf.
 */
int* total_number_of_books;

/*
 * This stores the total number of pages in each book of each shelf.
 * The rows represent the shelves and the columns represent the books.
 */
int** total_number_of_pages;
int main()
{
    int total_number_of_shelves;
    if (scanf("%d", &total_number_of_shelves) != 1) return 0;
    
    int total_number_of_queries;
    if (scanf("%d", &total_number_of_queries) != 1) return 0;
    
    // CRITICAL FIX: Allocate memory trackers for each shelf before running queries.
    // calloc sets values to 0/NULL so realloc acts predictably on first insertions.
    total_number_of_books = (int*)calloc(total_number_of_shelves, sizeof(int));
    total_number_of_pages = (int**)calloc(total_number_of_shelves, sizeof(int*));
    
    while (total_number_of_queries--) {
        int type_of_query;
        if (scanf("%d", &type_of_query) != 1) continue;
        
        if (type_of_query == 1) {
            int x, y;
            if (scanf("%d %d", &x, &y) != 2) continue;
            
            // Get the current number of books on shelf x
            int current_book_count = total_number_of_books[x];
            
            // Dynamically resize the column array for shelf x to accommodate one more book
            total_number_of_pages[x] = (int*)realloc(total_number_of_pages[x], (current_book_count + 1) * sizeof(int));
            
            // Insert the new book's page count at the end of the shelf
            total_number_of_pages[x][current_book_count] = y;
            
            // Increment the total number of books on shelf x
            total_number_of_books[x]++;
        } else if (type_of_query == 2) {
            int x, y;
            scanf("%d %d", &x, &y);
            printf("%d\n", *(*(total_number_of_pages + x) + y));
        } else {
            int x;
            scanf("%d", &x);
            printf("%d\n", *(total_number_of_books + x));
        }
    }

    if (total_number_of_books) {
        free(total_number_of_books);
    }
    
    for (int i = 0; i < total_number_of_shelves; i++) {
        if (*(total_number_of_pages + i)) {
            free(*(total_number_of_pages + i));
        }
    }
    
    if (total_number_of_pages) {
        free(total_number_of_pages);
    }
    
    return 0;
}
