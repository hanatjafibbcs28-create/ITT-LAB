# Read the total number of test cases
num_test_cases = int(input().strip())

# Process each test case line by line
for _ in range(num_test_cases):
    try:
        # Read and split the input tokens safely
        a_str, b_str = input().split()
        
        # Perform integer division using floor division //
        result = int(a_str) // int(b_str)
        print(result)
        
    except ZeroDivisionError:
        # Hardcode the exact historical string required by the platform criteria
        print("Error Code: integer division or modulo by zero")
        
    except ValueError as e:
        # ValueError messages match modern environments perfectly
        print("Error Code:", e)
