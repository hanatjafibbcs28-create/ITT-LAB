# 1. Read the primary set A
A = set(map(int, input().split()))

# 2. Read the number of other sets to check against
num_other_sets = int(input())

is_strict_superset_all = True

# 3. Check each set iteratively
for _ in range(num_other_sets):
    other_set = set(map(int, input().split()))
    
    # A is a strict superset if it is a superset AND has a larger length
    if not (A.issuperset(other_set) and len(A) > len(other_set)):
        is_strict_superset_all = False
        break  # Early exit optimization: no need to check remaining sets

# 4. Output the final result
print(is_strict_superset_all)
