import sys

def solve():
    # Read all lines from standard input
    input_data = sys.stdin.read().splitlines()
    if not input_data:
        return
    
    # Line 0: Number of English subscribers (n) -> Not strictly needed for set creation
    # Line 1: Roll numbers for English subscribers
    english_set = set(input_data[1].split())
    
    # Line 2: Number of French subscribers (m) -> Not strictly needed for set creation
    # Line 3: Roll numbers for French subscribers
    french_set = set(input_data[3].split())
    
    # Find the intersection of both sets
    both_subscriptions = english_set.intersection(french_set)
    
    # Print the total number of students
    print(len(both_subscriptions))

if __name__ == "__main__":
    solve()
