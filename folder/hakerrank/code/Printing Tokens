#include <stdio.h>
#include <string.h>
#include <stdlib.h>

int main() {
    char *s;
    s = malloc(1024 * sizeof(char));
    
    if (scanf("%[^\n]%*c", s) == 1) {
        // Extract the first token (word) using space as a delimiter
        char *token = strtok(s, " ");
        
        // Keep printing and extracting tokens until no words are left
        while (token != NULL) {
            printf("%s\n", token);
            token = strtok(NULL, " "); // Pass NULL to continue parsing the same string
        }
    }
    
    free(s);
    return 0;
}
