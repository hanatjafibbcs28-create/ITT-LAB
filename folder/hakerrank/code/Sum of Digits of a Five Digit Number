#include <stdio.h>

int main() {
    int n;
    int sum = 0;
    
    // Read the five-digit integer
    if (scanf("%d", &n) == 1) {
        
        // Loop to extract each of the 5 digits
        while (n > 0) {
            sum += n % 10; // Extract the last digit and add to sum
            n /= 10;       // Remove the last digit via integer truncation
        }
        
        // Print the final sum of the digits
        printf("%d\n", sum);
    }
    
    return 0;
}
