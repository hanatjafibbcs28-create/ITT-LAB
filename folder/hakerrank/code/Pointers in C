#include <stdio.h>
#include <stdlib.h> // Required for the abs() function

void update(int *a, int *b) {
    // 1. Store the original values pointed to by 'a' and 'b'
    int original_a = *a;
    int original_b = *b;
    
    // 2. Assign the sum of both numbers to the memory address of 'a'
    *a = original_a + original_b;
    
    // 3. Assign the absolute difference to the memory address of 'b'
    *b = abs(original_a - original_b);
}

int main() {
    int a, b;
    int *pa = &a, *pb = &b;
    
    if (scanf("%d %d", &a, &b) == 2) {
        update(pa, pb);
        printf("%d\n%d\n", a, b);
    }
    return 0;
}
